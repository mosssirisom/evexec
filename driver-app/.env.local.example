# Supabase — public keys, safe for the browser
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# NEVER add SUPABASE_SERVICE_ROLE_KEY here.
# All driver-side operations use RLS + the anon key.
# Service-role operations belong in the main evexec API only.
